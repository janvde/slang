#!/usr/bin/env bash
#
# slangc - Slang Compiler Script
# Compiles .slang source files to native executables
#
# Usage: slangc <input.slang> [output_binary]
#        slangc --help
#

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Functions
print_usage() {
    cat << EOF
${BLUE}Slang Compiler${NC} - Compile .slang files to native executables

${GREEN}Usage:${NC}
    slangc <input.slang> [output_binary]
    slangc --help
    slangc --version

${GREEN}Arguments:${NC}
    input.slang      Source file to compile (required)
    output_binary    Output executable name (optional, defaults to 'output')

${GREEN}Options:${NC}
    --help           Show this help message
    --version        Show version information
    --keep-ir        Keep the intermediate LLVM IR file
    --verbose        Show detailed compilation output
    --run            Run the executable after compilation

${GREEN}Examples:${NC}
    slangc hello.slang              # Compiles to './output'
    slangc hello.slang hello        # Compiles to './hello'
    slangc hello.slang --run        # Compile and run
    slangc test.slang --keep-ir     # Keep LLVM IR file

${GREEN}Requirements:${NC}
    - Java Runtime Environment (JRE)
    - Gradle (or use ./gradlew)
    - LLVM tools (llc, clang) for native compilation

${GREEN}Environment Variables:${NC}
    SLANG_VERBOSE    Set to 1 for verbose output
    SLANG_KEEP_IR    Set to 1 to keep intermediate files

EOF
}

print_version() {
    echo "Slang Compiler version 1.0-SNAPSHOT"
    echo "Built on $(date)"
}

error() {
    echo -e "${RED}Error:${NC} $1" >&2
    exit 1
}

info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

verbose() {
    if [[ "$VERBOSE" == "1" ]]; then
        echo -e "${BLUE}[VERBOSE]${NC} $1"
    fi
}

check_dependencies() {
    # Check for Java
    if ! command -v java &> /dev/null; then
        error "Java is not installed. Please install Java Runtime Environment."
    fi

    verbose "Java found: $(java -version 2>&1 | head -n 1)"

    # Check for Gradle wrapper or gradle
    if [[ ! -f "$SCRIPT_DIR/gradlew" ]] && ! command -v gradle &> /dev/null; then
        error "Gradle is not installed and gradlew not found."
    fi

    # Check for LLVM tools (optional but recommended)
    if ! command -v llc &> /dev/null; then
        warn "llc not found. Native compilation may not be available."
        warn "Install LLVM tools for native executable generation."
    fi

    if ! command -v clang &> /dev/null; then
        warn "clang not found. Native compilation may not be available."
        warn "Install clang for native executable generation."
    fi
}

# Parse arguments
INPUT_FILE=""
OUTPUT_FILE="output"
KEEP_IR=0
VERBOSE=${SLANG_VERBOSE:-0}
RUN_AFTER=0

while [[ $# -gt 0 ]]; do
    case $1 in
        --help|-h)
            print_usage
            exit 0
            ;;
        --version|-v)
            print_version
            exit 0
            ;;
        --keep-ir)
            KEEP_IR=1
            shift
            ;;
        --verbose)
            VERBOSE=1
            shift
            ;;
        --run)
            RUN_AFTER=1
            shift
            ;;
        -*)
            error "Unknown option: $1"
            ;;
        *)
            if [[ -z "$INPUT_FILE" ]]; then
                INPUT_FILE="$1"
            else
                OUTPUT_FILE="$1"
            fi
            shift
            ;;
    esac
done

# Validate input
if [[ -z "$INPUT_FILE" ]]; then
    error "No input file specified. Use --help for usage information."
fi

if [[ ! -f "$INPUT_FILE" ]]; then
    error "Input file not found: $INPUT_FILE"
fi

if [[ ! "$INPUT_FILE" =~ \.slang$ ]]; then
    warn "Input file does not have .slang extension"
fi

# Check dependencies
check_dependencies

# Setup paths
INPUT_ABSOLUTE="$(cd "$(dirname "$INPUT_FILE")" && pwd)/$(basename "$INPUT_FILE")"
OUTPUT_ABSOLUTE="$(cd "$(dirname "${OUTPUT_FILE:-.}")" 2>/dev/null && pwd)/$(basename "$OUTPUT_FILE")" || OUTPUT_ABSOLUTE="$PWD/$OUTPUT_FILE"
IR_FILE="${OUTPUT_ABSOLUTE}.ll"
OBJ_FILE="${OUTPUT_ABSOLUTE}.o"

info "Compiling $INPUT_FILE -> $OUTPUT_FILE"
verbose "Input: $INPUT_ABSOLUTE"
verbose "Output: $OUTPUT_ABSOLUTE"
verbose "IR file: $IR_FILE"

# Choose gradle command
if [[ -f "$SCRIPT_DIR/gradlew" ]]; then
    GRADLE="$SCRIPT_DIR/gradlew"
else
    GRADLE="gradle"
fi

# Compile with Slang compiler
info "Running Slang compiler..."

cd "$SCRIPT_DIR"

if [[ "$VERBOSE" == "1" ]]; then
    "$GRADLE" run --args="$INPUT_ABSOLUTE $IR_FILE" --console=plain
    COMPILE_STATUS=$?
else
    "$GRADLE" run --args="$INPUT_ABSOLUTE $IR_FILE" --console=plain 2>&1 | grep -E "LOG|Error|error|FAILED" || true
    COMPILE_STATUS=$?
fi

if [[ $COMPILE_STATUS -ne 0 ]]; then
    error "Compilation failed. Check the error messages above."
fi

# Check if IR file was generated
if [[ ! -f "$IR_FILE" ]]; then
    error "LLVM IR file was not generated: $IR_FILE"
fi

info "LLVM IR generated successfully"

# Check if native executable was created by the compiler
if [[ -f "$OUTPUT_ABSOLUTE" ]]; then
    info "Native executable generated: $OUTPUT_ABSOLUTE"

    # Make it executable
    chmod +x "$OUTPUT_ABSOLUTE"

    # Cleanup intermediate files if requested
    if [[ "$KEEP_IR" == "0" ]]; then
        verbose "Cleaning up intermediate files..."
        rm -f "$IR_FILE" "$OBJ_FILE"
    else
        info "Kept LLVM IR file: $IR_FILE"
    fi

    echo -e "${GREEN}✓ Compilation successful!${NC}"
    echo -e "  Executable: ${BLUE}$OUTPUT_ABSOLUTE${NC}"

    # Show file size
    if command -v stat &> /dev/null; then
        SIZE=$(stat -f%z "$OUTPUT_ABSOLUTE" 2>/dev/null || stat -c%s "$OUTPUT_ABSOLUTE" 2>/dev/null)
        echo -e "  Size: $(numfmt --to=iec-i --suffix=B $SIZE 2>/dev/null || echo "${SIZE} bytes")"
    fi

    # Run if requested
    if [[ "$RUN_AFTER" == "1" ]]; then
        echo ""
        info "Running executable..."
        echo "--- Output ---"
        "$OUTPUT_ABSOLUTE"
        echo "--- End Output ---"
    fi

    exit 0
else
    warn "Native executable was not created automatically"
    info "Attempting manual compilation with llc and clang..."

    # Try to compile with llc and clang
    if command -v llc &> /dev/null && command -v clang &> /dev/null; then
        verbose "Compiling IR to object file..."
        if llc -filetype=obj "$IR_FILE" -o "$OBJ_FILE" 2>&1; then
            verbose "Linking object file..."
            if clang "$OBJ_FILE" -o "$OUTPUT_ABSOLUTE" 2>&1; then
                chmod +x "$OUTPUT_ABSOLUTE"

                # Cleanup
                if [[ "$KEEP_IR" == "0" ]]; then
                    verbose "Cleaning up intermediate files..."
                    rm -f "$IR_FILE" "$OBJ_FILE"
                else
                    info "Kept LLVM IR file: $IR_FILE"
                    info "Kept object file: $OBJ_FILE"
                fi

                echo -e "${GREEN}✓ Compilation successful!${NC}"
                echo -e "  Executable: ${BLUE}$OUTPUT_ABSOLUTE${NC}"

                if [[ "$RUN_AFTER" == "1" ]]; then
                    echo ""
                    info "Running executable..."
                    echo "--- Output ---"
                    "$OUTPUT_ABSOLUTE"
                    echo "--- End Output ---"
                fi

                exit 0
            else
                error "Failed to link object file"
            fi
        else
            error "Failed to compile IR to object file"
        fi
    else
        echo -e "${YELLOW}Note:${NC} LLVM IR file generated at: $IR_FILE"
        echo "Install llc and clang to compile to native executable:"
        echo "  llc -filetype=obj $IR_FILE -o ${OUTPUT_FILE}.o"
        echo "  clang ${OUTPUT_FILE}.o -o $OUTPUT_FILE"
        exit 1
    fi
fi

